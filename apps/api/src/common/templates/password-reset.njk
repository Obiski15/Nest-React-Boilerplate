{% extends "base.njk" %}

{% block content %}
  <h1 style="margin-top: 0; margin-bottom: 20px; font-size: 24px; font-weight: 700; color: {{ theme.text_heading }};">
    Reset your password
  </h1>
  
  <p style="margin-top: 0; margin-bottom: 24px;">
    Hi {{ user.name | default('there') }},
  </p>

  <p style="margin-top: 0; margin-bottom: 24px;">
    We received a request to reset the password for your {{ app.name }} account. Click the button below to choose a new, secure password.
  </p>

  <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 30px;">
    <tr>
      <td align="center">
        <table border="0" cellpadding="0" cellspacing="0">
          <tr>
            <td align="center" style="border-radius: 6px; background-color: {{ theme.primary }};">
              <a href="{{ action_url }}" target="_blank" style="display: inline-block; padding: 14px 30px; font-family: Helvetica, Arial, sans-serif; font-size: 16px; font-weight: bold; color: {{ theme.button_text }}; text-decoration: none; border-radius: 6px; border: 1px solid {{ theme.primary }};">
                Reset Password
              </a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <p style="margin-top: 0; margin-bottom: 10px;">
    <strong>Note:</strong> This link will expire in 15 minutes.
  </p>
  
  <p style="margin-top: 0; margin-bottom: 0;">
    If you did not request a password reset, your account is perfectly safe. You can ignore this email and nothing will change.
  </p>
{% endblock %}