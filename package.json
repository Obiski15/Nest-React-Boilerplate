{
  "name": "boilerplate",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "exports": {
    "./tsconfig.base.json": "./tsconfig.base.json"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@app/web",
    "dev:api": "turbo dev --filter=@app/api",
    "build:web": "turbo build --filter=@app/web",
    "build:api": "turbo build --filter=@app/api",
    "start:web": "turbo start --filter=@app/web",
    "start:api": "turbo start --filter=@app/api",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:cov": "turbo test:cov",
    "test:debug": "turbo test:debug",
    "test:e2e": "turbo test:e2e",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "lint": "turbo lint",
    "lint:staged": "eslint --fix",
    "format": "turbo format -- --ignore-path ../../.prettierignore",
    "format:staged": "prettier --write",
    "format:check": "turbo format:check -- --ignore-path ../../.prettierignore",
    "type-check": "turbo type-check"
  },
  "lint-staged": {
    "*.ts": [
      "pnpm lint:staged",
      "pnpm format:staged"
    ],
    "*.{js,json,md,yml,yaml}": [
      "pnpm format:staged"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "axios": "^1.16.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "latest",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
